[node name="TextContent" type="Label" parent="VBoxContainer"]
layout_mode=2
text="This game depicts depression, suicidal ideation, and self-harm as part of its story. The descent is meant to be uncomfortable; that discomfort is the design.

If at any point you need to step away, the game saves continuously and will be here when you return.

If you are struggling beyond the game – call or text 988 in the United States, or visit findahelpline.com to find a crisis line near you.

You are seen."
wrap_text=true

[node name="ContinueButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner=true
